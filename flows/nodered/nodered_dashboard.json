  {
    "id": "inject-oee",
    "type": "inject",
    "z": "tab-smfg",
    "name": "Calcular OEE cada minuto",
    "props": [{"p": "payload"}],
    "repeat": "60",
    "crontab": "",
    "once": true,
    "onceDelay": 2,
    "payload": "",
    "payloadType": "date",
    "x": 150,
    "y": 340,
    "wires": [["calc-oee"]]
  },
  {
    "id": "calc-oee",
    "type": "function",
    "z": "tab-smfg",
    "name": "Calcular OEE simulado",
    "func": "// OEE = Disponibilidad × Rendimiento × Calidad\n// En modo simulación usamos valores realistas variables\nconst disponibilidad = 0.90 + (Math.random() * 0.08);\nconst rendimiento = 0.88 + (Math.random() * 0.10);\nconst calidad = 0.95 + (Math.random() * 0.04);\nconst oee = disponibilidad * rendimiento * calidad;\n\nmsg.payload = parseFloat((oee * 100).toFixed(1));\nmsg.disponibilidad = parseFloat((disponibilidad * 100).toFixed(1));\nmsg.rendimiento = parseFloat((rendimiento * 100).toFixed(1));\nmsg.calidad = parseFloat((calidad * 100).toFixed(1));\n\nreturn msg;",
    "outputs": 1,
    "x": 400,
    "y": 340,
    "wires": [["gauge-oee", "text-disp", "text-rend", "text-cal"]]
  },
  {
    "id": "gauge-oee",
    "type": "ui_gauge",
    "z": "tab-smfg",
