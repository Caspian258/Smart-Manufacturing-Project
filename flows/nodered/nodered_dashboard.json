  {
    "id": "parse-energy",
    "type": "function",
    "z": "tab-smfg",
    "name": "Parsear energía",
    "func": "const d = msg.payload;\n\n// Potencia actual\nmsg.power = { payload: d.power_w || 0 };\n\n// Corriente\nmsg.irms = { payload: parseFloat((d.irms_a || 0).toFixed(2)) };\n\n// Estado ciclo\nmsg.cycle = { payload: d.cycle_active ? '🔴 EN CICLO: ' + (d.part_id || '') : '⚪ Sin ciclo' };\n\n// Modo\nmsg.mode = { payload: d.simulated ? '🟡 SIMULACIÓN' : '🟢 REAL' };\n\n// Gauge de potencia\nmsg.payload = d.power_w || 0;\n\nreturn msg;",
    "outputs": 1,
    "x": 360,
    "y": 100,
    "wires": [["gauge-power", "text-cycle", "text-mode", "chart-power"]]
  },
  {
    "id": "parse-heartbeat",
    "type": "function",
    "z": "tab-smfg",
    "name": "Parsear heartbeat",
    "func": "const d = msg.payload;\nmsg.payload = '🟢 Online — ' + (d.device || '') + ' | RSSI: ' + (d.rssi || 0) + ' dBm | Uptime: ' + Math.floor((d.uptime || 0)/60) + ' min';\nreturn msg;",
    "outputs": 1,
    "x": 360,
    "y": 200,
    "wires": [["text-status"]]
  },
