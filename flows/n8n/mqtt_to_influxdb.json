{
  "name": "Smart Manufacturing — MQTT to InfluxDB",
  "nodes": [
    {
      "parameters": {
        "protocol": "mqtt",
        "host": "localhost",
        "port": 1883,
        "username": "smfg_user",
        "password": "={{ $env.MQTT_PASSWORD }}",
        "topics": [
          { "topic": "cima/machines/+/energy" },
          { "topic": "cima/machines/+/cycle" },
          { "topic": "cima/rfid/scan" },
          { "topic": "celda3105/vision/result" },
          { "topic": "celda3105/rfid/scan" },
          { "topic": "celda3105/cobot/status" }
        ]
      },
      "id": "mqtt-trigger",
      "name": "MQTT Trigger — Todos los sensores",
      "type": "n8n-nodes-base.mqtt",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Parsear y enriquecer datos del mensaje MQTT\nconst topic = $input.item.json.topic || '';\nconst raw = $input.item.json.message || '{}';\nlet data;\ntry { data = JSON.parse(raw); } catch(e) { data = { raw }; }\n\n// Determinar planta y tipo\nlet plant = topic.startsWith('cima') ? 'cima' : 'celda3105';\nlet dataType = topic.split('/').slice(-1)[0];\n\n// Agregar metadata\ndata._plant = plant;\ndata._topic = topic;\ndata._dataType = dataType;\ndata._receivedAt = new Date().toISOString();\n\nreturn { json: data };"
      },
      "id": "enrich-data",
      "name": "Enriquecer datos",
      "type": "n8n-nodes-base.code",
      "position": [480, 300]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            { "conditions": { "string": [{ "value1": "={{ $json._plant }}", "operation": "equals", "value2": "cima" }] }, "output": 0 },
            { "conditions": { "string": [{ "value1": "={{ $json._plant }}", "operation": "equals", "value2": "celda3105" }] }, "output": 1 }
          ]
        }
      },
      "id": "router",
      "name": "Router por planta",
      "type": "n8n-nodes-base.switch",
      "position": [720, 300]
    },
    {
      "parameters": {
        "url": "http://localhost:8086/api/v2/write",
        "authentication": "headerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Token {{ $env.INFLUX_TOKEN }}" },
            { "name": "Content-Type", "value": "text/plain; charset=utf-8" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "org", "value": "smart-manufacturing" },
            { "name": "bucket", "value": "sensor-data" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={{ 'cima_energy,machine=' + $json.machine_id + ' power_w=' + ($json.power_w || 0) + ',irms_a=' + ($json.irms_a || 0) + ',energy_kwh=' + ($json.energy_kwh || 0) + ' ' + (new Date($json.ts || Date.now()).getTime() * 1000000) }}"
            }
          ]
        }
      },
      "id": "influx-cima",
      "name": "InfluxDB — CIMA Energy",
      "type": "n8n-nodes-base.httpRequest",
      "position": [960, 200]
    },
    {
      "parameters": {
        "url": "http://localhost:8086/api/v2/write",
        "authentication": "headerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Token {{ $env.INFLUX_TOKEN }}" },
            { "name": "Content-Type", "value": "text/plain; charset=utf-8" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "org", "value": "smart-manufacturing" },
            { "name": "bucket", "value": "sensor-data" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "body",
              "value": "={{ 'celda3105_event,type=' + $json._dataType + ' value=1 ' + (new Date().getTime() * 1000000) }}"
            }
          ]
        }
      },
      "id": "influx-celda",
      "name": "InfluxDB — Celda 3105",
      "type": "n8n-nodes-base.httpRequest",
      "position": [960, 400]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            { "value1": "={{ $json.power_w }}", "operation": "largerEqual", "value2": 3000 }
          ]
        }
      },
      "id": "anomaly-check",
      "name": "Detección anomalía (consumo alto)",
      "type": "n8n-nodes-base.if",
      "position": [1200, 200]
    },
    {
      "parameters": {
        "jsCode": "// Generar alerta de anomalía para el dashboard\nconst data = $input.item.json;\nreturn {\n  json: {\n    alert_type: 'HIGH_POWER',\n    severity: data.power_w > 5000 ? 'critical' : 'warning',\n    machine: data.machine_id,\n    power_w: data.power_w,\n    message: `Consumo anómalo en ${data.machine_id}: ${data.power_w}W`,\n    ts: new Date().toISOString()\n  }\n};"
      },
      "id": "generate-alert",
      "name": "Generar alerta",
      "type": "n8n-nodes-base.code",
      "position": [1440, 160]
    },
    {
      "parameters": {
        "protocol": "mqtt",
        "host": "localhost",
        "port": 1883,
        "username": "smfg_user",
        "password": "={{ $env.MQTT_PASSWORD }}",
        "topic": "smfg/alerts",
        "qos": 1
      },
      "id": "publish-alert",
      "name": "Publicar alerta MQTT",
      "type": "n8n-nodes-base.mqtt",
      "position": [1680, 160]
    }
  ],
  "connections": {
    "MQTT Trigger — Todos los sensores": {
      "main": [[{ "node": "Enriquecer datos", "type": "main", "index": 0 }]]
    },
    "Enriquecer datos": {
      "main": [[{ "node": "Router por planta", "type": "main", "index": 0 }]]
    },
    "Router por planta": {
      "main": [
        [{ "node": "InfluxDB — CIMA Energy", "type": "main", "index": 0 }],
        [{ "node": "InfluxDB — Celda 3105", "type": "main", "index": 0 }]
      ]
    },
    "InfluxDB — CIMA Energy": {
      "main": [[{ "node": "Detección anomalía (consumo alto)", "type": "main", "index": 0 }]]
    },
    "Detección anomalía (consumo alto)": {
      "main": [[{ "node": "Generar alerta", "type": "main", "index": 0 }], []]
    },
    "Generar alerta": {
      "main": [[{ "node": "Publicar alerta MQTT", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "_meta": {
    "description": "Flujo principal: recibe todos los mensajes MQTT, los enruta por planta, los guarda en InfluxDB y detecta anomalías.",
    "version": "1.0.0",
    "last_updated": "2024-01"
  }
}
