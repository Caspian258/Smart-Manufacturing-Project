          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      },
      "title": "Potencia Actual",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SMARTMFG}" },
          "query": "from(bucket: \"sensor-data\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cima_energy\")\n  |> filter(fn: (r) => r._field == \"power_w\")\n  |> last()\n  |> yield(name: \"last\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SMARTMFG}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "amp",
          "min": 0,
          "max": 15
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 2,
