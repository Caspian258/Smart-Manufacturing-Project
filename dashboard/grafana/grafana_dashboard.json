      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SMARTMFG}" },
          "query": "from(bucket: \"sensor-data\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r._measurement == \"cima_energy\")\n  |> filter(fn: (r) => r._field == \"power_w\")\n  |> aggregateWindow(every: 1m, fn: max, createEmpty: false)\n  |> yield(name: \"max\")",
          "refId": "A"
