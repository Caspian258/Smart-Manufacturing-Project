            "matcher": { "id": "byName", "options": "simulated" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "1": { "text": "🟡 SIM" }, "0": { "text": "🟢 REAL" } }, "type": "value" }
