            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1500 },
              { "color": "red", "value": 2500 }
            ]
          },
          "unit": "watt",
          "min": 0,
          "max": 3000
