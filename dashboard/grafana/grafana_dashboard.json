      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SMARTMFG}" },
          "query": "from(bucket: \"sensor-data\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"cima_energy\")\n  |> filter(fn: (r) => r._field == \"irms_a\")\n  |> last()\n  |> yield(name: \"last\")",
          "refId": "A"
        }
      ]
    },
