      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["count"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Ciclos Hoy",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SMARTMFG}" },
          "query": "from(bucket: \"sensor-data\")\n  |> range(start: today())\n  |> filter(fn: (r) => r._measurement == \"cima_energy\")\n  |> filter(fn: (r) => r._field == \"cycle_active\")\n  |> filter(fn: (r) => r._value == true)\n  |> count()\n  |> yield(name: \"count\")",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "${DS_INFLUXDB_SMARTMFG}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "power_w" },
            "properties": [
              { "id": "displayName", "value": "Potencia (W)" },
              { "id": "unit", "value": "watt" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 1500 },
                  { "color": "red", "value": 2500 }
                ]
              }}
